<Window x:Class="StockWatchdog.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="480"
        Height="735"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="监控设置" FontSize="20" FontWeight="SemiBold"/>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="行情刷新（3–60 秒）" VerticalAlignment="Center"/>
            <TextBox x:Name="RefreshSecondsTextBox" Grid.Column="1"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="老板键" VerticalAlignment="Center"/>
            <TextBox x:Name="HotkeyTextBox" Grid.Column="1" ToolTip="例如 Ctrl+Alt+H"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="界面皮肤" VerticalAlignment="Center"/>
            <ComboBox x:Name="ThemeComboBox"
                      Grid.Column="1"
                      DisplayMemberPath="Name"
                      SelectionChanged="OnThemeSelectionChanged"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="150,8,0,0">
            <Button Content="导入主题" Click="OnImportThemeClick"/>
            <Button Content="导出所选" Margin="8,0,0,0" Click="OnExportThemeClick"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,18,0,0">
            <CheckBox x:Name="AlwaysOnTopCheckBox" Content="浮窗始终置顶" Margin="0,4"/>
            <CheckBox x:Name="SoundEnabledCheckBox" Content="提醒时播放提示音" Margin="0,4"/>
            <CheckBox x:Name="StartHiddenCheckBox" Content="启动后保持托盘隐藏" Margin="0,4"/>
            <CheckBox x:Name="StartWithWindowsCheckBox" Content="随 Windows 启动" Margin="0,4"/>
        </StackPanel>

        <GroupBox Grid.Row="6" Header="小浮窗模式" Margin="0,16,0,0" Padding="10">
            <ComboBox x:Name="CompactModeComboBox">
                <ComboBoxItem Content="丰富模式：标题、添加栏、表格和状态栏"/>
                <ComboBoxItem Content="简洁模式：只显示中央表格"/>
            </ComboBox>
        </GroupBox>

        <GroupBox Grid.Row="7" Header="做 T 双评分提醒" Margin="0,12,0,0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="54"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="54"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <CheckBox x:Name="TScoreEnabledCheckBox"
                          Grid.ColumnSpan="5"
                          Content="达到候选阈值时弹窗并播放提醒"
                          Margin="0,0,0,8"/>
                <TextBlock Grid.Row="1" Text="阈值（60–95）" VerticalAlignment="Center"/>
                <TextBox x:Name="TScoreThresholdTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="6,0,14,0"
                         Padding="5,3"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Text="冷却（1–240 分钟）"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="TScoreCooldownTextBox"
                         Grid.Row="1"
                         Grid.Column="3"
                         Margin="6,0,0,0"
                         Padding="5,3"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="8" Header="小浮窗列" Margin="0,12,0,0" Padding="10">
            <UniformGrid Columns="4">
                <CheckBox x:Name="ShowNameCheckBox" Content="名称" Margin="0,3"/>
                <CheckBox x:Name="ShowCodeCheckBox" Content="代码" Margin="0,3"/>
                <CheckBox x:Name="ShowPriceCheckBox" Content="现价" Margin="0,3"/>
                <CheckBox x:Name="ShowChangeCheckBox" Content="涨跌" Margin="0,3"/>
                <CheckBox x:Name="ShowSignalCheckBox" Content="做T评分" Margin="0,3"/>
                <CheckBox x:Name="ShowSparklineCheckBox" Content="走势" Margin="0,3"/>
                <CheckBox x:Name="ShowTimeCheckBox" Content="更新时间" Margin="0,3"/>
            </UniformGrid>
        </GroupBox>

        <Border Grid.Row="9"
                Margin="0,18,0,8"
                Padding="10"
                Background="{DynamicResource SelectionBrush}"
                CornerRadius="{DynamicResource SquareCellRadius}">
            <StackPanel>
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="买卖分数表示量价条件匹配强度，不代表成功率。免费公开行情无 SLA，延迟、过期或主备源冲突时评分会自动暂停。"/>
                <StackPanel Orientation="Horizontal"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Right">
                    <TextBlock Text="设备迁移"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedForegroundBrush}"/>
                    <Button Content="导出全部配置"
                            Padding="8,3"
                            Click="OnExportConfigurationClick"/>
                    <Button Content="导入配置文本"
                            Margin="7,0,0,0"
                            Padding="8,3"
                            Click="OnImportConfigurationClick"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="ErrorTextBlock"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{DynamicResource WarningBrush}"/>
            <Button Content="取消" Width="76" Click="OnCancelClick"/>
            <Button Content="保存" Width="76" Margin="8,0,0,0" Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
