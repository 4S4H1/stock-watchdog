<Window x:Class="StockWatchdog.App.Views.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="技术形态分析"
        Width="760"
        Height="700"
        MinWidth="640"
        MinHeight="520"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Topmost="True"
        KeyDown="OnKeyDown">
    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource GridLineBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource SquareCellRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="58"/>
                <RowDefinition Height="64"/>
                <RowDefinition Height="300"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{DynamicResource SurfaceBrush}"
                  MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding SelectedRow.Name}"
                               FontSize="15"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedRow.Code}"
                               Margin="8,2,0,0"
                               Foreground="{DynamicResource MutedForegroundBrush}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="×"
                        Command="{Binding CloseDetailCommand}"
                        Padding="12,4"
                        BorderThickness="0"/>
            </Grid>

            <Grid Grid.Row="1" Margin="12,8,12,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding SelectedRow.PriceText}"
                               FontSize="22"
                               FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedRow.IsPositive}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedRow.IsNegative}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource NegativeBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding SelectedRow.ChangePercentText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedRow.IsPositive}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedRow.IsNegative}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource NegativeBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="1"
                        Margin="14,2"
                        Padding="8,4"
                        Background="{DynamicResource SelectionBrush}"
                        CornerRadius="{DynamicResource SquareCellRadius}">
                    <StackPanel>
                        <TextBlock Text="{Binding RegimeText}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedRow.QualityText}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,3"
                                ToolTip="{Binding SelectedRow.TSignalSummary}">
                        <TextBlock Text="买入条件 "
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock Text="{Binding SelectedRow.BuyScoreText}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PositiveBrush}"/>
                        <TextBlock Text="  ·  卖出条件 "
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock Text="{Binding SelectedRow.SellScoreText}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource NegativeBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding AnalysisStatus}"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding IndicatorSummary}"
                               Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <ComboBox Grid.Column="3"
                          Width="96"
                          ItemsSource="{Binding Timeframes}"
                          SelectedItem="{Binding SelectedTimeframe}"
                          DisplayMemberPath="Label"
                          VerticalAlignment="Center"/>
            </Grid>

            <Border Grid.Row="2"
                    Margin="12,4,12,2"
                    Padding="8,5"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource GridLineBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource SquareCellRadius}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="指标"
                                       Margin="0,2,8,0"
                                       FontWeight="SemiBold"/>
                            <CheckBox x:Name="ShowEma5CheckBox"
                                      Content="EMA5"
                                      IsChecked="True"
                                      Margin="0,0,9,0"
                                      Click="OnIndicatorVisibilityChanged"/>
                            <CheckBox x:Name="ShowEma10CheckBox"
                                      Content="EMA10"
                                      IsChecked="True"
                                      Margin="0,0,9,0"
                                      Click="OnIndicatorVisibilityChanged"/>
                            <CheckBox x:Name="ShowEma20CheckBox"
                                      Content="EMA20"
                                      IsChecked="True"
                                      Margin="0,0,9,0"
                                      Click="OnIndicatorVisibilityChanged"/>
                            <CheckBox x:Name="ShowVwapCheckBox"
                                      Content="VWAP"
                                      IsChecked="True"
                                      Margin="0,0,9,0"
                                      Click="OnIndicatorVisibilityChanged"/>
                            <CheckBox x:Name="ShowBollingerCheckBox"
                                      Content="布林带"
                                      IsChecked="True"
                                      Margin="0,0,9,0"
                                      Click="OnIndicatorVisibilityChanged"/>
                            <CheckBox x:Name="ShowSupportResistanceCheckBox"
                                      Content="支撑/阻力"
                                      IsChecked="True"
                                      Margin="0,0,9,0"
                                      Click="OnIndicatorVisibilityChanged"/>
                            <CheckBox x:Name="ShowAlertThresholdsCheckBox"
                                      Content="提醒阈值"
                                      IsChecked="True"
                                      Click="OnIndicatorVisibilityChanged"/>
                        </StackPanel>
                    </ScrollViewer>
                    <Grid Grid.Row="1" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="MarkerStatusText"
                                   Text="Ctrl+左键买 · Ctrl+右键卖 · 双击框体删除"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="ClearTradeMarkersButton"
                                Grid.Column="1"
                                Content="清除当前标记"
                                Padding="8,1"
                                FontSize="11"
                                Click="OnClearTradeMarkersClick"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Margin="12,4"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource GridLineBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource SquareCellRadius}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalysisHealthy}" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScottPlot:WpfPlot x:Name="AnalysisPlot"
                                   PreviewMouseLeftButtonDown="OnPlotPreviewMouseLeftButtonDown"
                                   PreviewMouseRightButtonDown="OnPlotPreviewMouseRightButtonDown"
                                   PreviewMouseDoubleClick="OnPlotPreviewMouseDoubleClick"/>
            </Border>

            <ScrollViewer Grid.Row="4"
                          Margin="12,5"
                          VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Opacity" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalysisHealthy}" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Findings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,7"
                                    Padding="10"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource GridLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource SquareCellRadius}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Rationale}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        <ItemsControl ItemsSource="{Binding Evidence}" Margin="0,5,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="• " Foreground="{DynamicResource AccentBrush}"/>
                                                        <TextBlock Text="{Binding Description}"/>
                                                        <TextBlock Text=" · "
                                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                        <TextBlock Text="{Binding Actual, StringFormat={}{0:0.###}}"
                                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                        <TextBlock Text=" "
                                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                        <TextBlock Text="{Binding Comparator}"
                                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                        <TextBlock Text=" "
                                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                        <TextBlock Text="{Binding Threshold, StringFormat={}{0:0.###}}"
                                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                        <TextBlock Text="{Binding Unit}"
                                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Invalidation, StringFormat=失效：{0}}"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding DetectedAt, StringFormat=触发 {0:MM-dd HH:mm}}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource MutedForegroundBrush}"/>
                                            <TextBlock Text="{Binding ValidUntil, StringFormat= · 有效至 {0:HH:mm}}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource MutedForegroundBrush}"/>
                                            <TextBlock Text="{Binding AnalyzerVersion, StringFormat= · 规则 {0}}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Margin="10,0,0,0"
                                            Padding="8,4"
                                            Background="{DynamicResource SelectionBrush}"
                                            CornerRadius="4"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Score, StringFormat={}{0} 分}"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="5" Margin="12,5,12,9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="图表标记仅用于本地复盘，不代表实际委托或成交"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedForegroundBrush}"/>
                <Button Grid.Column="1"
                        Margin="6,0"
                        Content="设置提醒"
                        Command="{Binding OpenAlertsCommand}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
